# Required: official GMGN CLI credentials.
GMGN_API_KEY=
# Keep the project-local CLI so production uses the version pinned in package-lock.json.
GMGN_CLI_PATH=node_modules/.bin/gmgn-cli
GMGN_POLL_INTERVAL_MS=15000
GMGN_TRENCHES_LIMIT=80

# X narrative snapshots via api.fxtwitter.com.
TWITTER_POLL_INTERVAL_MS=300000

# Robinhood Chain mainnet (chain ID 4663). Use an Alchemy URL in production if available.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_EXPLORER_URL=https://robinhoodchain.blockscout.com
DEPLOYER_CACHE_MS=300000

# Deterministic alpha alerts.
MIN_ALPHA_SCORE=45
MIN_LIQUIDITY_USD=0
ALERT_COOLDOWN_MS=1800000
POLL_INTERVAL_MS=5000
NEW_LISTING_BATCH_INTERVAL_MS=120000
NEW_LISTING_BATCH_LIMIT=5

# Private Telegram group.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_IDS=
